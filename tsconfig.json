{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@bukeer/website-contract": [
        "./packages/website-contract/src"
      ],
      "@bukeer/website-contract/*": [
        "./packages/website-contract/src/*"
      ],
      "@bukeer/theme-sdk": [
        "./packages/theme-sdk/src"
      ],
      "@bukeer/theme-sdk/*": [
        "./packages/theme-sdk/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-epic86-e2e/types/**/*.ts",
    ".next-epic86-e2e2/types/**/*.ts",
    ".next-epic86/types/**/*.ts",
    ".next-s1/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-epic86-e2e3/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
