{
  "name": "@bukeer/theme-sdk",
  "version": "3.0.0",
  "description": "Theme Platform v3 — canonical design tokens, theme profiles, and compiler for Bukeer websites",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./contracts/*": "./src/contracts/*",
    "./sdk/*": "./src/sdk/*",
    "./compiler/*": "./src/compiler/*",
    "./guardrails/*": "./src/guardrails/*",
    "./presets/*": "./src/presets/*"
  },
  "dependencies": {
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  },
  "files": ["src", "dist"]
}
