{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "supabase": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env.mcp ] && source .env.mcp; set +a; npx -y @supabase/mcp-server-supabase@latest --access-token \"$SUPABASE_ACCESS_TOKEN\""
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "shadcn-ui": {
      "command": "npx",
      "args": ["-y", "shadcn-ui-mcp-server"]
    },
    "magic-ui": {
      "command": "npx",
      "args": ["-y", "magicui-mcp"]
    },
    "aceternity-ui": {
      "command": "npx",
      "args": ["-y", "aceternity-ui-mcp"]
    },
    "google-analytics": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env.mcp ] && source .env.mcp; set +a; pipx run analytics-mcp"
      ]
    },
    "search-console": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env.mcp ] && source .env.mcp; set +a; npx -y search-console-mcp@latest"
      ]
    },
    "dataforseo": {
      "command": "bash",
      "args": [
        "-lc",
        "ENV_FILE=\"/Users/yeisongomez/Documents/Proyectos/Bukeer/bukeer-studio/.env.local\"; set -a; [ -f \"$ENV_FILE\" ] && source \"$ENV_FILE\"; set +a; export DATAFORSEO_USERNAME=\"${DATAFORSEO_LOGIN:-$DATAFORSEO_USERNAME}\"; export DATAFORSEO_PASSWORD=\"$DATAFORSEO_PASSWORD\"; exec npx -y dataforseo-mcp-server@latest"
      ],
      "env": {
        "ENABLED_MODULES": "SERP,KEYWORDS_DATA,DATAFORSEO_LABS,BACKLINKS"
      }
    },
    "bukeer-studio": {
      "command": "node",
      "args": [".claude/mcp-servers/bukeer-studio/dist/index.js"],
      "env": {
        "BUKEER_BASE_URL": "http://localhost:3000",
        "BUKEER_SERVICE_ROLE_KEY": "${BUKEER_SERVICE_ROLE_KEY}",
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}"
      }
    }
  }
}
