{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "supabase": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env.mcp ] && source .env.mcp; set +a; npx -y @supabase/mcp-server-supabase@latest --access-token \"$SUPABASE_ACCESS_TOKEN\""
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "shadcn-ui": {
      "command": "npx",
      "args": ["-y", "shadcn-ui-mcp-server"]
    },
    "magic-ui": {
      "command": "npx",
      "args": ["-y", "magicui-mcp"]
    },
    "aceternity-ui": {
      "command": "npx",
      "args": ["-y", "aceternity-ui-mcp"]
    },
    "google-analytics": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env.mcp ] && source .env.mcp; set +a; pipx run analytics-mcp"
      ]
    },
    "search-console": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env.mcp ] && source .env.mcp; set +a; npx -y search-console-mcp@latest"
      ]
    },
    "dataforseo": {
      "command": "node",
      "args": [".claude/mcp-servers/dataforseo/dist/index.js"],
      "env": {
        "DATAFORSEO_LOGIN": "${DATAFORSEO_LOGIN}",
        "DATAFORSEO_PASSWORD": "${DATAFORSEO_PASSWORD}",
        "DATAFORSEO_MONTHLY_CAP_USD": "50",
        "DATAFORSEO_BASE_URL": "https://api.dataforseo.com"
      }
    },
    "bukeer-studio": {
      "command": "node",
      "args": [".claude/mcp-servers/bukeer-studio/dist/index.js"],
      "env": {
        "BUKEER_BASE_URL": "http://localhost:3000",
        "BUKEER_SERVICE_ROLE_KEY": "${BUKEER_SERVICE_ROLE_KEY}",
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}"
      }
    }
  }
}
