{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "supabase": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env.mcp ] && source .env.mcp; set +a; npx -y @supabase/mcp-server-supabase@latest --access-token \"$SUPABASE_ACCESS_TOKEN\""
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "shadcn-ui": {
      "command": "npx",
      "args": ["-y", "shadcn-ui-mcp-server"]
    },
    "magic-ui": {
      "command": "npx",
      "args": ["-y", "magicui-mcp"]
    },
    "aceternity-ui": {
      "command": "npx",
      "args": ["-y", "aceternity-ui-mcp"]
    },
    "google-analytics": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env.mcp ] && source .env.mcp; set +a; pipx run analytics-mcp"
      ]
    },
    "search-console": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f .env.mcp ] && source .env.mcp; set +a; npx -y search-console-mcp@latest"
      ]
    }
  }
}
