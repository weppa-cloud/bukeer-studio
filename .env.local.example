# bukeer-studio — local environment
# Copy to .env.local and fill with real values. Never commit .env.local.
# All variables are validated by lib/env.ts at runtime.

# ─── Supabase (shared with bukeer-flutter) ──────────────────────────────
# Same project as the Flutter app. Get values from the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — optional in dev, REQUIRED in production.
# Never expose to the client; used by server-side routes and Edge API calls.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI integration (OpenRouter) ────────────────────────────────────────
OPENROUTER_AUTH_TOKEN=sk-or-v1-your-token
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ─── ISR revalidation ───────────────────────────────────────────────────
# Any random string. Used by /api/revalidate to protect the endpoint.
REVALIDATE_SECRET=change-me-to-a-random-string

# ─── Public URLs ────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_MAIN_DOMAIN=bukeer.com

# ─── Maps (MapLibre GL) ─────────────────────────────────────────────────
# Base-style URL. Required in production; optional in dev (falls back to
# demotiles.maplibre.org, which is unstyled).
#
# Recommended provider: MapTiler free-tier (100k map loads / month).
#   1. Sign up at https://www.maptiler.com/cloud/
#   2. Create an API key in the dashboard
#   3. Paste it into NEXT_PUBLIC_MAP_STYLE_TOKEN
#
# {token} in the URL is replaced with NEXT_PUBLIC_MAP_STYLE_TOKEN at runtime
# (see destination-map.tsx → resolveMapStyleUrl).
# Pick any MapTiler style: streets-v2, voyager, outdoor-v2, satellite, etc.
NEXT_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key={token}
NEXT_PUBLIC_MAP_STYLE_TOKEN=your-maptiler-api-key

# MapTiler Geocoding API (server-only; fills places_cache misses)
MAPTILER_GEOCODING_KEY=

# ─── Analytics (optional) ───────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
