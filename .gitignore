# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# local MCP server builds
/.claude/mcp-servers/*/dist/
/.claude/mcp-servers/*/node_modules/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/.sessions/

# parallel next.js build caches (session isolation)
/.next-*/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.dev.vars.example
!.claude/mcp-servers/*/.env.example

# MCP config — contains tokens, never commit
.mcp.json
.mcp.local.json

# Cloudflare Workers (OpenNext build output)
.open-next/
.dev.vars
.dev.vars.*
!.dev.vars.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
web-public/.wrangler/

# Packages build artifacts
packages/*/dist/
packages/*/node_modules/
packages/*/tsconfig.tsbuildinfo

# QA / test tool outputs
.playwright-mcp/
/playwright/.cache/
qa-screenshots/
colombiatours-full.png
reports/
*.png
!__tests__/visual/studio-editor-baselines/**/*.png
!public/
!public/tenant-icons/
!public/tenant-icons/**/*.png

# Lighthouse CI reports
.lighthouseci/

# Local MCP servers — build output, deps, cache, budget state
.claude/mcp-servers/*/dist/
.claude/mcp-servers/*/node_modules/
.claude/mcp-servers/dataforseo/cache/*
!.claude/mcp-servers/dataforseo/cache/.gitkeep
.claude/mcp-servers/dataforseo/budget.json
.claude/mcp-servers/dataforseo/budget.json.*.bak
.claude/worktrees/
artifacts/

# Supabase CLI local project metadata
supabase/.temp/
