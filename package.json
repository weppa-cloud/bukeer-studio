    "test:e2e:session": "bash scripts/run-e2e-session.sh",
    "test:e2e:evolucion": "E2E_SKIP_ROUTE_PREWARM=1 NEXT_DEV_TURBO=false playwright test e2e/tests/evolucion-f*.spec.ts --project=chromium --no-deps",
    "test:e2e:evolucion:session": "E2E_SKIP_ROUTE_PREWARM=1 NEXT_DEV_TURBO=false bash scripts/session-acquire.sh --run e2e/tests/evolucion-f*.spec.ts --project=chromium --no-deps",
    "test:e2e:evolucion:core": "E2E_SKIP_ROUTE_PREWARM=1 NEXT_DEV_TURBO=false playwright test e2e/tests/evolucion-f[1-9]-*.spec.ts e2e/tests/evolucion-f11-*.spec.ts --project=chromium --no-deps",
    "test:e2e:evolucion:core:session": "E2E_SKIP_ROUTE_PREWARM=1 NEXT_DEV_TURBO=false bash scripts/session-acquire.sh --run e2e/tests/evolucion-f[1-9]-*.spec.ts e2e/tests/evolucion-f11-*.spec.ts --project=chromium --no-deps",
    "test:e2e:evolucion:f3-guard:session": "E2E_SKIP_ROUTE_PREWARM=1 NEXT_DEV_TURBO=false ADMIN_NEXT_WRITES_ITINERARIES_ENABLED=false ADMIN_NEXT_E2E_WRITE_ITINERARIES=false PLAYWRIGHT_JSON_OUTPUT_NAME=playwright-report/evolucion-f3-guarded/results.json bash scripts/session-acquire.sh --run e2e/tests/evolucion-f3-itinerary-create-modal.spec.ts --project=chromium --no-deps --grep \"mantiene el submit cerrado sin flag de writes\"",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:ct:update": "playwright test -c playwright-ct.config.ts --update-snapshots",
