{
  "name": "web-public",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10 <12"
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.mjs",
    "clean": "rm -rf .next .open-next playwright-report test-results",
    "ai:sync": "node scripts/ai/sync-from-claude.mjs",
    "ai:check": "node scripts/ai/check-ai-sync.mjs",
    "ai:hooks:install": "node scripts/ai/install-hooks.mjs",
    "ai:audit": "node scripts/ai/audit-skills.mjs",
    "tech-validator:code": "node scripts/ai/validate-tech-validator.mjs",
    "tech-validator:code:quick": "node scripts/ai/validate-tech-validator.mjs --quick",
    "media:guardrails": "node scripts/ai/check-media-asset-guardrails.mjs",
    "dev": "npm run check:node && npm run dev:node",
    "dev:node": "bash scripts/start-dev-node.sh",
    "dev:session": "bash scripts/start-dev-node.sh",
    "dev:worker": "npm run check:node && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "build": "next build",
    "build:ci": "npm run check:node && next build",
    "start": "next start",
    "start:prod:clean": "bash scripts/start-prod-clean.sh",
    "lint": "next lint && npm run lint:hardcoded-ui",
    "lint:hardcoded-ui": "node scripts/lint-hardcoded-public-ui.mjs",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "test": "jest --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:session": "bash scripts/run-e2e-session.sh",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:ct:update": "playwright test -c playwright-ct.config.ts --update-snapshots",
    "session:run": "bash scripts/session-acquire.sh --run",
    "session:list": "bash scripts/session-list.sh",
    "session:release": "bash scripts/session-release.sh",
    "seo:validate-blog-work-items": "node scripts/seo/validate-blog-work-items.mjs",
    "test:watch": "jest --watch",
    "build:worker": "npm run check:node && opennextjs-cloudflare build",
    "preview:worker": "npm run check:node && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:worker": "npm run check:node && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "tech-validator:code:strict": "node scripts/ai/validate-tech-validator.mjs --strict-global",
    "tech-validator:code:strict:full": "node scripts/ai/validate-tech-validator.mjs --strict-global-full"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.46",
    "@ai-sdk/react": "^3.0.142",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@playwright/test": "^1.59.1",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@tiptap/suggestion": "^2.27.2",
    "@types/sharp": "^0.31.1",
    "@vis.gl/react-maplibre": "^8.1.1",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.19.1",
    "isomorphic-dompurify": "^2.35.0",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^0.523.0",
    "maplibre-gl": "^5.23.0",
    "marked": "^17.0.1",
    "next": "^15.3.9",
    "next-themes": "^0.4.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.58.1",
    "shadcn": "^4.1.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.8.10",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@lhci/cli": "^0.14.0",
    "@next/bundle-analyzer": "^16.1.1",
    "@playwright/experimental-ct-react": "^1.59.1",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.9",
    "jest": "^29.7.0",
    "lighthouse": "^12.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5",
    "wrangler": "^4.76.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
