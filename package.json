    "@tiptap/starter-kit": "^2.11.5",
    "tiptap-markdown": "^0.8.10",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.19.1",
    "isomorphic-dompurify": "^2.35.0",
    "lucide-react": "^0.523.0",
    "marked": "^17.0.1",
    "next": "^15.3.9",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.58.1",
    "tailwind-merge": "^3.3.1",
