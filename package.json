    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5",
    "wrangler": "^4.76.0"
  }
